{
  "name": "ai-session-bridge",
  "version": "0.1.0-preview",
  "description": "Bridge your AI coding sessions between OpenAI Codex CLI and Anthropic Claude Code CLI. Convert JSONL sessions bidirectionally and continue where you left off.",
  "type": "module",
  "bin": {
    "ai-session-bridge": "./src/cli.ts"
  },
  "scripts": {
    "bridge": "tsx src/cli.ts",
    "list": "tsx src/cli.ts list",
    "test": "node -e \"const {spawnSync}=require('child_process');let r;if(process.platform==='win32'){const comspec=process.env.ComSpec||'cmd.exe';r=spawnSync(comspec,['/d','/s','/c','npx tsx src/cli.ts list --json'],{stdio:'ignore'});}else{r=spawnSync('npx',['tsx','src/cli.ts','list','--json'],{stdio:'ignore'});}if(r.status===0)console.log('OK');process.exit(r.status??1);\""
  },
  "keywords": [
    "codex",
    "claude",
    "claude-code",
    "openai",
    "anthropic",
    "session",
    "bridge",
    "converter",
    "cli",
    "ai-coding",
    "jsonl",
    "codex-cli",
    "claude-code-cli"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0"
  }
}
